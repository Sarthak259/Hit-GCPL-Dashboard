# Copy these as Environment Variables in Railway's dashboard
# (Project -> Variables). Do NOT commit a real .env file.

GROQ_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NEWSDATA_API_KEY=
OWM_API_KEY=
WAQI_API_KEY=

# Path to the persistent Railway Volume mount (see README for setup).
# If you don't attach a volume, leave this unset — the app will still
# run, but users.json edits and uploaded dengue-burden data will be
# lost on every redeploy/restart.
DATA_DIR=/data
